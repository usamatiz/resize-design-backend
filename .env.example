NODE_ENV=development
PORT=8080

# Frontend URL — invitees are redirected here after accepting an invite
APP_URL=http://localhost:3000
# Backend URL — used in invitation email links
API_URL=http://localhost:8080
INVITE_REDIRECT_PATH=/auth/set-password
# Secret for short-lived invite setup tokens (32+ random characters)
INVITE_SETUP_SECRET=change-me-to-a-long-random-string

# Postgres / Supabase Postgres connection (used by TypeORM)
# Grab from: Supabase → Project Settings → Database → Connection string → "Session pooler" tab → URI
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Do NOT use the "Transaction pooler" (port 6543) — it breaks TypeORM migrations.
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres
DB_SSL=true

# Supabase HTTP client
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — used to deliver invitation + transactional emails
RESEND_API_KEY=re_your_resend_api_key
# Verified sender: e.g. "Your App <no-reply@yourapp.com>"
MAIL_FROM=Acme <onboarding@resend.dev>

# Anthropic (Claude) — used by the projects/designs module to resize Polotno JSON
ANTHROPIC_API_KEY=sk-ant-your-key
# Optional; defaults to claude-sonnet-4-6 if unset
ANTHROPIC_MODEL=claude-sonnet-4-6

# Polotno Cloud Render API — used to rasterize resized JSON into PNG server-side
# Get key at https://polotno.com/cabinet
POLOTNO_API_KEY=nFA5H9elEytDyPyvKL7T
